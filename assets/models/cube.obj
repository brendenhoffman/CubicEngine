# Unit cube (1x1x1) centered at (0, 0, -2), triangulated with normals and UVs.
# Placed on the -Z axis so the default camera (at origin, looking -Z) sees it
# immediately. Use WASD to navigate around it.

# Positions (8 corners)
v -0.5 -0.5 -1.5
v  0.5 -0.5 -1.5
v  0.5  0.5 -1.5
v -0.5  0.5 -1.5
v -0.5 -0.5 -2.5
v  0.5 -0.5 -2.5
v  0.5  0.5 -2.5
v -0.5  0.5 -2.5

# UVs (4 canonical corners, reused per face)
vt 0.0 0.0
vt 1.0 0.0
vt 1.0 1.0
vt 0.0 1.0

# Face normals (6 outward directions)
vn  0.0  0.0  1.0
vn  0.0  0.0 -1.0
vn  0.0  1.0  0.0
vn  0.0 -1.0  0.0
vn  1.0  0.0  0.0
vn -1.0  0.0  0.0

# Faces: v/vt/vn (1-indexed, CCW winding from outside = front-facing for our pipeline)

# Front  (+Z face)
f 1/1/1 2/2/1 3/3/1
f 1/1/1 3/3/1 4/4/1

# Back   (-Z face)
f 5/1/2 8/4/2 7/3/2
f 5/1/2 7/3/2 6/2/2

# Top    (+Y face)
f 4/1/3 3/2/3 7/3/3
f 4/1/3 7/3/3 8/4/3

# Bottom (-Y face)
f 1/1/4 5/4/4 6/3/4
f 1/1/4 6/3/4 2/2/4

# Right  (+X face)
f 2/1/5 6/2/5 7/3/5
f 2/1/5 7/3/5 3/4/5

# Left   (-X face)
f 1/1/6 4/2/6 8/3/6
f 1/1/6 8/3/6 5/4/6
